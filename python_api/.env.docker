SECRET_KEY=supersecret123
# Docker gateway ismini de güvenli listeye ekliyoruz
ACCEPT_URL=http://localhost,http://127.0.0.1,host.docker.internal

# 1. QDRANT (Mac'te çalışıyorsa)
#QDRANT_URL=http://my_qdrant_db_arama_motoru_yeni:6333
QDRANT_URL=http://host.docker.internal:6333
COLLECTION_NAME=ollama_my_rag_collection


# 2. POSTGRESQL (Mac'te çalışıyorsa)
#HOST=rag_postgres_yeni
HOST=host.docker.internal
DATABASE=arama_motoru_db
DB_USER=postgres
PASSWORD=gizlisifrem
PORT=5432

# 3. REDIS (Docker Compose içindeki servis adını kullanmalısın!)
# Eğer docker-compose.yml'da servis adın 'redis_broker' ise:
REDIS_HOST=redis_broker
REDIS_PORT=6379


OLLAMA_BASE_URL=http://host.docker.internal:11434
#OLLAMA_MODEL=qwen3.5:0.8b-q8_0
#EMBEDDING_MODEL=all-minilm
#DIMENSION=384
OLLAMA_MODEL=gemma3:4b
EMBEDDING_MODEL=embeddinggemma
DIMENSION=768